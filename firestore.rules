/**
 * This ruleset enforces a security model for the eBikeNow rental application.
 *
 * Core Philosophy:
 * The model provides a mix of public and private access. Bike information is public
 * for anonymous browsing, while user data and rental history are strictly private.
 * Administrative privileges, managed via a separate 'roles_admin' collection,
 * are required for managing the bike inventory.
 *
 * Data Structure:
 * - /users/{userId}: Private user profile data.
 * - /users/{userId}/rentals/{rentalId}: A denormalized, user-specific copy of their
 *   rentals, optimized for secure and efficient listing ("My Rentals" screen).
 * - /bikes/{bikeId}: Publicly readable list of all bikes and their status.
 * - /rentals/{rentalId}: A master collection of all rental records. This collection
 *   is used for creating and managing individual rentals but is not listable by clients.
 * - /roles_admin/{userId}: A lookup collection to grant admin rights. The existence
 *   of a document here signifies an admin user. This collection is not client-writable.
 *
 * Key Security Decisions:
 * - Admin roles are managed out-of-band (e.g., via the Firebase Console or a trusted
 *   backend) by making the /roles_admin collection read-only from the client.
 * - User enumeration is disabled by disallowing list operations on the /users collection for non-admins.
 * - Rental data is segregated into two collections: a private, listable subcollection
 *   (/users/{userId}/rentals) and a non-listable top-level collection (/rentals)
 *   for transactional writes. This prevents users from listing each other's rentals.
 *
 * Denormalization for Authorization:
 * Each document in the /rentals and /users/{userId}/rentals collections contains a
 * 'userId' field. This denormalization is critical, as it allows security rules
 * to verify ownership directly from the document itself without performing costly
 * and slow `get()` calls to other documents.
 *
 * Structural Segregation:
 * The separation of rental data into a private user subcollection (/users/{userId}/rentals)
 * and a master top-level collection (/rentals) is a deliberate choice. It provides
 * a highly secure and performant way for users to list only their own rentals while
 * allowing the system to manage rental creation in a central location.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Returns true if the user has an admin role document.
     * This is the correct, full path for the exists() function.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * Returns true if the document being written to already exists.
     * Used for safe update/delete operations.
     */
    function isExistingDocument() {
      return resource != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the 'userId'
     * field in the document's data.
     */
    function isDocumentOwner(doc) {
      return isOwner(doc.data.userId);
    }
    
    /**
     * Returns true if a document exists and its 'userId' field matches the
     * authenticated user's UID.
     */
    function isExistingDocumentOwner(doc) {
      return isExistingDocument() && isDocumentOwner(doc);
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    /**
     * @description Users can create and manage their own profile. Admins can read/write all profiles.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      
      /**
       * @description A user can manage their own rentals within their own user space.
       */
      match /rentals/{rentalId} {
        allow read, list, write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Admins can check for their own role, but cannot write or list roles.
     */
    match /roles_admin/{userId} {
      allow get: if isOwner(userId);
      allow list, write: if false;
    }

    /**
     * @description Bike data is public for viewing, but only admins can manage the inventory.
     */
    match /bikes/{bikeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Master rentals collection. Users can create their own rentals. Admins can manage all.
     */
    match /rentals/{rentalId} {
      allow read, write: if isExistingDocumentOwner(resource) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow list: if isAdmin();
    }
  }
}
